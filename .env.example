# ── RIFTBRAWL / Archway Games — Supabase configuration ───────────────────────
# Copy to `.env` (and load it however you run the server — e.g. `node --env-file=.env
# server/index.js` on Node 22+), or set these as real secrets in production.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Public anon key — safe to expose; the browser uses it for "Sign in with Archway".
# Served to the client at GET /config.
SUPABASE_ANON_KEY=

# Service-role key — SECRET. The game server uses it to read/write the social
# graph and verify access tokens. Never ship this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional
# PORT=3000
# SMASH_TRACE=1            # log non-input ws messages
# SMASH_DATA_DIR=./data    # where the /design Skin Forge stores skins.json + uploaded images

# ── one-time Supabase setup ──────────────────────────────────────────────────
# 1. Run supabase/schema.sql in the SQL Editor (creates profiles / friendships /
#    friend_requests, the sign-up trigger, helper RPCs, and the is_admin flag).
# 2. Auth → Providers → Email: enable it. For zero-friction sign-up, turn OFF
#    "Confirm email" so new Archway accounts get a session immediately.
# 3. Grant yourself /design access:
#    update public.profiles set is_admin = true where username = 'YourTag';
