# Copy this file to `.env` (which is gitignored) and edit.
# Real environment variables always take precedence over anything set here.

# Comma-separated fighter tags allowed to open /design (the Skin Forge).
# Sign in to the game with one of these tags, then visit /design.
DESIGN_ROLES=yourtag

# Where accounts (smash.db) + skins (skins.json, skins/) are stored.
# Defaults to ./data locally and /data in the container.
# SMASH_DATA_DIR=./data

# HTTP port (default 3000).
# PORT=3000
